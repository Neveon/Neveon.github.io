---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Recent Projects' },
];
---

<header class="sticky top-0 z-40 border-b border-slate-200/60 bg-white/80 backdrop-blur dark:border-stone-800/60 dark:bg-stone-950/80">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="#top" class="text-sm font-semibold tracking-tight text-slate-900 dark:text-stone-100">
      Neil Tellez
    </a>
    <div class="flex items-center gap-6">
      <ul class="hidden items-center gap-6 text-sm text-slate-600 sm:flex dark:text-stone-400">
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class="transition hover:text-[var(--accent)]">{label}</a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>
