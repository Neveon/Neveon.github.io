---
const links = [
  { href: 'https://github.com/Neveon', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/neiltellez/', label: 'LinkedIn' },
  { href: 'mailto:neil.tellez.dev@gmail.com', label: 'Email' },
];

const resumeHref = '/Neil-Tellez-Resume.pdf';
---

<section id="top" class="mx-auto max-w-3xl px-6 pt-20 pb-16 sm:pt-28">
  <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl dark:text-stone-50">
    Neil Tellez
  </h1>
  <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-stone-400">
    Software Development Engineer
  </p>
  <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
    <a
      href={resumeHref}
      download
      class="inline-flex items-center gap-2 rounded-md bg-[var(--accent)] px-4 py-2 font-medium text-white shadow-sm transition hover:bg-[var(--accent-strong)] dark:text-stone-950"
    >
      Download résumé
      <span aria-hidden="true">↓</span>
    </a>
    <ul class="flex flex-wrap gap-x-6 gap-y-2">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            {...(href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="inline-flex items-center gap-1 font-medium text-[var(--accent)] transition hover:text-[var(--accent-strong)]"
          >
            {label}
            <span aria-hidden="true" class="text-slate-400">→</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
